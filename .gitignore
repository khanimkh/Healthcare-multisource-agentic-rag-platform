# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Build and packaging outputs
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment and secrets
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Test and coverage artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Jupyter
.ipynb_checkpoints/

# Node / frontend (React/Next.js)
node_modules/
.next/
out/
frontend/node_modules/
frontend/.next/
frontpage/node_modules/
frontpage/.next/
app/frontend/node_modules/
app/frontend/.next/

# Local data artifacts
app/backend/data/raw/*
app/backend/data/processed/*
app/backend/data/embeddings/*
app/backend/data/outputs/*
!app/backend/data/raw/.gitkeep
!app/backend/data/processed/.gitkeep
!app/backend/data/embeddings/.gitkeep
!app/backend/data/outputs/.gitkeep

